# ---------------------------------------------------------------------------
# Database (choose one of the two approaches below)
# ---------------------------------------------------------------------------

# Option A: direct connection (local / dev)
# All five must be set — if any are missing the app falls back to Option B.

# Option B: AWS Secrets Manager (production / Lambda)
# When set, Option A values above are ignored.
# DB_SECRET_ARN=arn:aws:secretsmanager:eu-west-2:123456789:secret:firesale/db

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AWS_REGION=eu-west-2

# ---------------------------------------------------------------------------
# AWS SES — email verification
# ---------------------------------------------------------------------------
# The "From" address must be verified in SES (or your domain must be verified).
SES_SENDER_EMAIL=trainee.tom.king@sigmalabs.co.uk
# Optional override if SES is in a different region to the rest of your stack
# SES_REGION=eu-west-1

# ---------------------------------------------------------------------------
# Streamlit app
# ---------------------------------------------------------------------------
# Public URL of the deployed app — used to build the verification link in emails.
# In dev, http://localhost:8501 works if you're testing locally.
APP_URL=https://localhost:8501
